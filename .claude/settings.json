{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "deny": [
      "Bash(taac2026 submit --execute*)",
      "Bash(rm -rf *)",
      "Bash(rm -rf /)",
      "Bash(git push --force*)",
      "Bash(git reset --hard*)",
      "Bash(cat *secrets/review.hmac.key*)",
      "Bash(cat *secrets/taiji.cookie*)",
      "Bash(less *secrets/*)",
      "Bash(head *secrets/*)",
      "Bash(tail *secrets/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {"type": "command", "command": ".claude/hooks/guard-bash.sh"}
        ]
      },
      {
        "matcher": "WebFetch",
        "hooks": [
          {"type": "command", "command": ".claude/hooks/guard-webfetch.sh"}
        ]
      }
    ]
  }
}
